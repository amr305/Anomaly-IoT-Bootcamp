# ==========================================
# ANOMALY IoT BOOTCAMP - .gitignore
# ==========================================

# ------------------------------------------
# Arduino IDE
# ------------------------------------------
*.ino.preprocessed
*.pde
*.cpp
*.c
*.h
*.bak
*.old
*.tmp

# ------------------------------------------
# Compiled files (huge! never upload these)
# ------------------------------------------
*.o
*.elf
*.hex
*.bin
*.eep
*.map

# ------------------------------------------
# PlatformIO (we will use this later)
# ------------------------------------------
.pio/
.vscode/
.idea/
*.sln
*.suo

# ------------------------------------------
# Mac & Windows system junk
# ------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.log
*.cache

# ------------------------------------------
# Wokwi exports (keep only the .ino file)
# ------------------------------------------
*.zip
*.rar
*.7z

# ------------------------------------------
# Temporary files
# ------------------------------------------
*.tmp
*.swp
*.swo
*~

# ------------------------------------------
# Node.js (for Firebase Cloud Functions)
# ------------------------------------------
node_modules/
.env
